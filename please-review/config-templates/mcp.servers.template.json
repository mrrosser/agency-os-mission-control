{
  "mcpServers": {
    "context7": {
      "url": "https://mcp.context7.com/mcp",
      "headers": {
        "CONTEXT7_API_KEY": "${MCP_CONTEXT7_API_KEY}"
      }
    },
    "magicuidesign-mcp": {
      "command": "npx",
      "args": [
        "-y",
        "@magicuidesign/mcp@latest"
      ]
    },
    "google-workspace": {
      "command": "node",
      "args": [
        "PLACEHOLDER_PATH_TO_GOOGLE_WORKSPACE_MCP_SERVER"
      ]
    },
    "firestore": {
      "command": "node",
      "args": [
        "PLACEHOLDER_PATH_TO_FIRESTORE_MCP_SERVER"
      ]
    },
    "smauto": {
      "url": "${SMAUTO_MCP_SERVER_URL}",
      "headers": {
        "Authorization": "Bearer ${SMAUTO_MCP_API_KEY}"
      }
    },
    "leadops": {
      "url": "${LEADOPS_MCP_SERVER_URL}",
      "headers": {
        "Authorization": "Bearer ${LEADOPS_MCP_API_KEY}"
      }
    }
  }
}
