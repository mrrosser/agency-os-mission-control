{
  "agents": {
    "defaults": {
      "workspace": "/home/openclaw/.openclaw/workspace",
      "model": {
        "primary": "openai/gpt-5"
      },
      "models": {
        "openai/gpt-5": {
          "alias": "brain"
        },
        "openai/gpt-5-mini": {
          "alias": "brain-fast"
        },
        "openai-codex/gpt-5.1-codex": {
          "alias": "codex"
        },
        "openai-codex/gpt-5.1-codex-mini": {
          "alias": "codex-fast"
        },
        "google/gemini-2.5-pro": {
          "alias": "gemini"
        },
        "google/gemini-2.5-flash": {
          "alias": "gemini-fast"
        },
        "google/gemini-2.5-flash-lite": {
          "alias": "gemini-lite"
        }
      }
    },
    "list": [
      {
        "id": "orchestrator",
        "workspace": "/home/openclaw/.openclaw/workspace",
        "description": "Master router for voice/chat. Delegates to business and functional specialists."
      },
      {
        "id": "biz-aicf",
        "workspace": "/home/openclaw/.openclaw/workspace-aicf",
        "description": "AI CoFoundry specialist"
      },
      {
        "id": "biz-rng",
        "workspace": "/home/openclaw/.openclaw/workspace-rng",
        "description": "Rosser NFT Gallery specialist"
      },
      {
        "id": "biz-rts",
        "workspace": "/home/openclaw/.openclaw/workspace-rts",
        "description": "RT Solutions specialist"
      },
      {
        "id": "fn-marketing",
        "workspace": "/home/openclaw/.openclaw/workspace-marketing",
        "description": "Marketing and social planning specialist"
      },
      {
        "id": "fn-research",
        "workspace": "/home/openclaw/.openclaw/workspace-research",
        "description": "Research specialist"
      },
      {
        "id": "fn-actions",
        "workspace": "/home/openclaw/.openclaw/workspace-actions",
        "description": "Single write agent for draft email + calendar actions"
      }
    ],
    "routing": {
      "default": "orchestrator",
      "triggers": [
        {
          "id": "biz_aicf",
          "matchAny": [
            "aicf",
            "ai cofoundry",
            "pilot",
            "managed ai ops"
          ],
          "agent": "biz-aicf"
        },
        {
          "id": "biz_rng",
          "matchAny": [
            "rng",
            "gallery",
            "commission",
            "exhibition",
            "event booking"
          ],
          "agent": "biz-rng"
        },
        {
          "id": "biz_rts",
          "matchAny": [
            "rt solutions",
            "school",
            "district",
            "workshop",
            "after-school"
          ],
          "agent": "biz-rts"
        },
        {
          "id": "fn_marketing",
          "intentAny": [
            "social_post",
            "campaign",
            "content_plan"
          ],
          "agent": "fn-marketing"
        },
        {
          "id": "fn_research",
          "intentAny": [
            "research",
            "market_intel",
            "competitor_scan"
          ],
          "agent": "fn-research"
        },
        {
          "id": "fn_actions",
          "intentAny": [
            "draft_email",
            "schedule_meeting",
            "create_calendar_invite",
            "crm_update"
          ],
          "agent": "fn-actions"
        }
      ]
    }
  },
  "logging": {
    "level": "info",
    "file": "/tmp/openclaw/openclaw.log",
    "consoleLevel": "info",
    "consoleStyle": "json",
    "redactSensitive": "tools"
  },
  "gateway": {
    "mode": "local",
    "auth": {
      "mode": "token",
      "token": "PLACEHOLDER_GATEWAY_TOKEN"
    }
  },
  "tools": {
    "deny": [],
    "web": {
      "search": {
        "enabled": true
      },
      "fetch": {
        "enabled": true
      }
    },
    "elevated": {
      "enabled": true,
      "allowFrom": {}
    }
  },
  "channels": {
    "googlechat": {
      "enabled": false,
      "serviceAccountFile": "/home/openclaw/.openclaw/credentials/openclaw-googlechat-sa.json",
      "audienceType": "app-url",
      "audience": "PLACEHOLDER_GOOGLE_CHAT_AUDIENCE",
      "webhookPath": "/googlechat",
      "botUser": "users/mcool44",
      "dm": {
        "enabled": true,
        "policy": "pairing",
        "allowFrom": [
          "PLACEHOLDER_GOOGLE_CHAT_DM"
        ]
      },
      "groupPolicy": "allowlist",
      "groups": {
        "spaces/AAQAJt-QD1I": {
          "allow": true,
          "requireMention": true
        }
      }
    },
    "telegram": {
      "enabled": false,
      "botToken": "PLACEHOLDER_TELEGRAM_BOT_TOKEN",
      "dmPolicy": "pairing",
      "allowFrom": [
        "PLACEHOLDER_TELEGRAM_USER"
      ],
      "groups": {
        "PLACEHOLDER_TELEGRAM_GROUP": {
          "requireMention": true
        }
      }
    }
  },
  "messages": {
    "tts": {
      "auto": "tagged",
      "mode": "final",
      "provider": "elevenlabs",
      "elevenlabs": {
        "voiceId": "PLACEHOLDER_ELEVENLABS_VOICE_ID",
        "modelId": "PLACEHOLDER_ELEVENLABS_MODEL_ID"
      }
    }
  },
  "plugins": {
    "entries": {
      "googlechat": {
        "enabled": true
      },
      "voice-call": {
        "enabled": false,
        "config": {
          "provider": "twilio",
          "fromNumber": "+15555550123",
          "toNumber": "+15555550124",
          "twilio": {
            "accountSid": "PLACEHOLDER_TWILIO_ACCOUNT_SID",
            "authToken": "PLACEHOLDER_TWILIO_AUTH_TOKEN"
          },
          "serve": {
            "port": 3334,
            "path": "/voice/webhook"
          },
          "streaming": {
            "enabled": true,
            "streamPath": "/voice/stream"
          },
          "runtime": {
            "conversationMode": "agentic",
            "entryAgentId": "orchestrator",
            "responseModel": "openai/gpt-4o-mini",
            "silenceDurationMs": 450,
            "businessResolver": {
              "fromNumberMap": {
                "+18443169534": "rosser_nft_gallery"
              },
              "defaultBusinessId": "ai_cofoundry"
            },
            "knowledge": {
              "enabled": true,
              "packPath": "/etc/openclaw/knowledge-packs/knowledge-pack.v2.json",
              "sharedPacks": [
                "shared_voice_and_policy.md"
              ],
              "routePacks": {
                "ai_cofoundry": [
                  "ai_cofoundry.md"
                ],
                "rosser_nft_gallery": [
                  "rosser_nft_gallery.md"
                ],
                "rt_solutions": [
                  "rt_solutions.md"
                ]
              }
            },
            "actionTools": {
              "enabled": [
                "gmail.createDraft",
                "calendar.createEvent",
                "calendar.createMeet",
                "crm.upsertLead"
              ],
              "writeAgentId": "fn-actions",
              "emailDraftOnly": true,
              "requireThreadLookup": true,
              "calendarRequireGoogleMeet": true,
              "calendarRequireTimezone": true,
              "humanApprovalForSend": true
            }
          }
        }
      }
    }
  }
}
